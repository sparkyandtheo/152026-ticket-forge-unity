rules_version = '2';

// =====================================================================
// Hamburg Door staff portal — Firestore security rules
//
// Policy: only @hamburgdoor.com Google accounts can read/write.
// There's no per-user role gating below that; any @hamburgdoor.com
// email has full access. When roles matter later, switch isStaff()
// to isOffice() / isTechnician() calls and issue custom claims.
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isStaff() {
      return request.auth != null
          && request.auth.token.email != null
          && request.auth.token.email.matches('.*@hamburgdoor[.]com');
    }

    // Business collections
    match /customers/{doc}         { allow read, write: if isStaff(); }
    match /phone_messages/{doc}    { allow read, write: if isStaff(); }
    match /sales_leads/{doc}       { allow read, write: if isStaff(); }
    match /quotes/{doc}            { allow read, write: if isStaff(); }
    match /work_orders/{doc}       { allow read, write: if isStaff(); }
    match /service_tickets/{doc}   { allow read, write: if isStaff(); }
    match /invoices/{doc}          { allow read, write: if isStaff(); }

    // Admin-console collections
    match /employees/{doc}         { allow read, write: if isStaff(); }
    match /inventory_items/{doc}   { allow read, write: if isStaff(); }
    match /gl_accounts/{doc}       { allow read, write: if isStaff(); }
    match /service_area_zips/{doc} { allow read, write: if isStaff(); }
    match /settings/{doc}          { allow read, write: if isStaff(); }

    // ID-generator counters
    match /counters/{doc}          { allow read, write: if isStaff(); }

    // Everything else: deny by default
    match /{document=**} { allow read, write: if false; }
  }
}
