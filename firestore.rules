rules_version = '2';

// =====================================================================
// Hamburg Door staff portal — Firestore security rules
//
// Policy: any signed-in user can read/write the business collections.
// This matches the current app: every staff member has a Google account
// in the hamburg-door-ops Firebase project, and there's no per-user RBAC
// wired yet. When we're ready to add roles, switch the `isAuthenticated()`
// calls to `isOffice()` / `isTechnician()` and issue custom claims.
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // --- helpers ---
    function isAuthenticated() {
      return request.auth != null;
    }

    // --- business collections ---
    match /customers/{doc}        { allow read, write: if isAuthenticated(); }
    match /phone_messages/{doc}   { allow read, write: if isAuthenticated(); }
    match /sales_leads/{doc}      { allow read, write: if isAuthenticated(); }
    match /quotes/{doc}           { allow read, write: if isAuthenticated(); }
    match /work_orders/{doc}      { allow read, write: if isAuthenticated(); }
    match /service_tickets/{doc}  { allow read, write: if isAuthenticated(); }
    match /invoices/{doc}         { allow read, write: if isAuthenticated(); }

    // --- admin-console collections ---
    match /employees/{doc}         { allow read, write: if isAuthenticated(); }
    match /inventory_items/{doc}   { allow read, write: if isAuthenticated(); }
    match /gl_accounts/{doc}       { allow read, write: if isAuthenticated(); }
    match /service_area_zips/{doc} { allow read, write: if isAuthenticated(); }
    match /settings/{doc}          { allow read, write: if isAuthenticated(); }

    // --- id-generator counters ---
    match /counters/{doc}         { allow read, write: if isAuthenticated(); }

    // --- everything else: deny by default ---
    match /{document=**} { allow read, write: if false; }
  }
}
