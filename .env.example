# .env.example — Hamburg Door staff portal
#
# No env vars are required for the static site today (Firebase config is
# public and embedded in public/js/firebase-config.js; access is gated by
# Firestore rules + Auth, not by secrecy).
#
# This file exists so that when Netlify Functions grow real logic, we have
# a documented place for their secrets.
#
# For local dev:  cp .env.example .env && fill in values
# For Netlify prod:  paste values in Netlify UI -> Site settings -> Environment

# --- Netlify Functions (stubs today, not implemented yet) ---

# Transcription provider API key (Gemini or OpenAI Whisper) — used by
# functions/transcribe.js
# GEMINI_API_KEY=
# OPENAI_API_KEY=

# Lead-time lookup vendor API (whoever supplies our parts catalog) — used by
# functions/lead-time.js
# PARTS_API_KEY=
# PARTS_API_URL=
